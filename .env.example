# GelGezGor Trend Pipeline - Environment Variables

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google Cloud (Vertex AI - Gemini & Imagen 3)
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Site
BASE_URL=https://www.gelgezgor.com

# Pipeline
CRON_SCHEDULE=0 9,15 * * *
DRY_RUN=true

# Meta Graph API (Instagram + Facebook)
META_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_id
FACEBOOK_PAGE_ID=your_fb_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_fb_page_token
# Public URL where images can be accessed (Meta API needs public URLs)
PUBLIC_BASE_URL=https://your-domain.com

# Panel
PORT=3000
