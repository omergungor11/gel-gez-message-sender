{
  "name": "gelgezgor-trend-pipeline",
  "version": "1.0.0",
  "description": "GelGezGor Trend İlanları Pipeline - WhatsApp Bildirim & Sosyal Medya İçerik Üretici",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/panel/server.ts",
    "start": "tsx src/panel/server.ts",
    "scrape": "tsx src/scraper/trendScraper.ts",
    "scrape:detail": "tsx src/scraper/detailScraper.ts",
    "pipeline": "tsx src/pipeline/index.ts",
    "pipeline:dry": "DRY_RUN=true tsx src/pipeline/index.ts",
    "cron": "tsx src/cron/index.ts",
