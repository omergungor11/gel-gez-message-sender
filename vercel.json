{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "src/panel/frontend",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/output/(.*)", "destination": "/api/image?file=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 9 * * *"
    }
  ]
}
